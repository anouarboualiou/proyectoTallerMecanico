{
  "version": 2,
  "builds": [
    {
      "src": "BACKEND/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "FRONTEND/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "BACKEND/server.js"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|ico|svg|woff2?))",
      "dest": "/FRONTEND/$1"
    },
    {
      "src": "/views/(.*)",
      "dest": "/FRONTEND/views/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/FRONTEND/index.html"
    }
  ]
}